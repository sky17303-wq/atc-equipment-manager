# 실제 키를 이 파일에 넣지 마세요. 이 파일을 .env로 복사한 뒤 .env에만 입력하세요.
PORT=5173
HOST=
BASE_PATH=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# 인증 모드:
# mock: 로컬 개발용 역할 선택
# hybrid: Supabase 세션이 있으면 자동 연결, 없으면 역할 선택 fallback
# supabase: 운영용. ERP/Supabase 로그인 세션만 신뢰
AUTH_MODE=mock
ERP_LOGIN_URL=/erp/login?from=/equipment/
EQUIPMENT_AUTO_MEMBER_STATUS=pending
# SUPABASE_URL=
# SUPABASE_ANON_KEY=

# 로컬 JSON 대신 PostgreSQL을 쓰려면 켭니다.
# DATABASE_URL 하나만 쓰거나, 아래 PGHOST/PGDATABASE/PGUSER/PGPASSWORD를 나누어 쓸 수 있습니다.
STORAGE_DRIVER=json
# STORAGE_DRIVER=postgres
# DATABASE_URL=postgres://equipment_user:비밀번호@101.79.21.9:5432/equipment_manager
# PGHOST=101.79.21.9
# PGPORT=5432
# PGDATABASE=equipment_manager
# PGUSER=equipment_user
# PGPASSWORD=비밀번호
# PGSSL=false

# 이메일 알림(SMTP): 미설정 시 발송하지 않고 알림 큐에 skipped로 기록됩니다.
# SMTP_SECURE: smtps(465, 즉시 TLS) | starttls(587 등) | 비우면 포트 기준 자동
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=
SMTP_FROM=

# 알림 디스패처: pending 이메일 발송 + 반납 기한 스윕 주기 (밀리초, 기본 60000)
NOTIFY_DISPATCH_INTERVAL_MS=60000
# 반납 기한 임박(due_soon) 알림 기준 일수 (기본 1일 이내 도래 시 알림)
NOTIFY_DUE_SOON_DAYS=1
# 카카오 알림톡 스텁: truthy면 email과 함께 kakao 채널 알림 엔트리도 생성 (발송기 미구현, pending 유지)
KAKAO_ENABLED=
